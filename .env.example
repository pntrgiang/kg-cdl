# ── Postgres (docker-compose) ─────────────────────────────
POSTGRES_USER=kg
POSTGRES_PASSWORD=kg_secret
POSTGRES_DB=kg_cdl
POSTGRES_PORT=5432
ADMINER_PORT=8081

# ── Backend (Go) ──────────────────────────────────────────
APP_ENV=development
HTTP_PORT=8080
# Múi giờ nghiệp vụ (IANA) — ghim cho DB & hiển thị, độc lập vị trí máy chủ (HK/SG/UTC)
APP_TIMEZONE=Asia/Ho_Chi_Minh
DATABASE_URL=postgres://kg:kg_secret@localhost:5432/kg_cdl?sslmode=disable

# JWT — đổi secret này ở production!
JWT_SECRET=change-me-in-production-please
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL=2160h   # 90 ngày

# CORS
CORS_ALLOW_ORIGIN=http://localhost:3000
